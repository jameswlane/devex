{
	"name": "devex",
	"version": "1.0.0",
	"description": "Used for release automation",
	"scripts": {
		"biome:format": "biome format --write",
		"biome:lint": "biome lint --write",
		"biome:check": "biome check --write",
		"build": "turbo build",
		"build:go": "turbo build:go",
		"generate": "turbo generate",
		"download": "turbo download",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"lint:go": "turbo lint:go",
		"lint:fix": "turbo lint:fix",
		"test": "turbo test",
		"test:go": "turbo test:go",
		"test:ginkgo": "turbo test:ginkgo",
		"clean": "turbo clean",
		"cli:build": "turbo build:go --filter=cli",
		"cli:test": "turbo test:go --filter=cli",
		"cli:lint": "turbo lint:go --filter=cli",
		"auto": "auto",
		"auto:version": "auto version",
		"auto:changelog": "auto changelog",
		"auto:release": "auto shipit",
		"web:build": "turbo build --filter=@devex/web",
		"web:dev": "turbo dev --filter=@devex/web",
		"web:generate": "node scripts/generate-web-tools-data.js",
		"docs:build": "turbo build --filter=docs",
		"docs:dev": "turbo dev --filter=docs",
		"goreleaser:generate": "node scripts/generate-goreleaser.js",
		"prerelease": "npm run goreleaser:generate"
	},
	"keywords": [],
	"author": "James W Lane",
	"license": "GPL-3.0",
	"packageManager": "pnpm@10.15.1",
	"devDependencies": {
		"@auto-it/conventional-commits": "^11.2.1",
		"@auto-it/core": "^11.2.1",
		"@biomejs/biome": "2.2.3",
		"@commitlint/config-conventional": "^19.8.1",
		"@commitlint/format": "^19.8.1",
		"@octokit/rest": "^22.0.0",
		"commitlint": "^19.8.0",
		"glob": "^11.0.3",
		"js-yaml": "^4.1.0",
		"turbo": "^2.5.6"
	}
}
