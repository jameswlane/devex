{
	"name": "cli",
	"version": "1.0.0",
	"description": "DevEx CLI - Development environment setup tool",
	"private": true,
	"scripts": {
		"build": "mkdir -p bin && go build -o bin/devex ./cmd/main.go",
		"build:go": "mkdir -p bin && go build -o bin/devex ./cmd/main.go",
		"build:local": "mkdir -p bin && go build -o bin/devex -v ./cmd/main.go",
		"postinstall": "go mod download && go mod tidy",
		"dev": "task dev:watch",
		"lint": "golangci-lint run || echo 'golangci-lint not available'",
		"lint:go": "golangci-lint run || echo 'golangci-lint not available'",
		"lint:fix": "golangci-lint run --fix || echo 'golangci-lint not available'",
		"test": "go test -v -coverprofile=coverage.out ./...",
		"test:go": "go test -v -coverprofile=coverage.out ./...",
		"test:ginkgo": "ginkgo run -r --timeout=5m --poll-progress-after=30s --poll-progress-interval=10s -v || echo 'ginkgo not available'",
		"test:integration": "timeout 10m ginkgo -r --timeout=5m --poll-progress-after=30s --poll-progress-interval=10s -v || echo 'ginkgo not available'",
		"test:coverage": "go tool cover -html=coverage.out -o coverage.html && echo 'Coverage report generated at coverage.html'",
		"vulncheck": "govulncheck ./... || echo 'govulncheck not available'",
		"clean": "rm -rf bin/ coverage.out coverage.html test-results.json",
		"ci": "go mod download && go mod tidy && go test ./... && go build -o bin/devex ./cmd/main.go"
	},
	"keywords": [
		"cli",
		"development",
		"environment",
		"setup",
		"automation",
		"go",
		"linux",
		"macos",
		"windows"
	],
	"author": "James W Lane",
	"license": "GPL-3.0"
}
