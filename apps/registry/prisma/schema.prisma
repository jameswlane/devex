// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  category    String
  official    Boolean  @default(false)
  default     Boolean  @default(false)
  tags        String[]
  
  // Platform support
  linuxSupport   PlatformInfo? @relation("LinuxSupport", fields: [linuxSupportId], references: [id])
  linuxSupportId String?
  
  macosSupport   PlatformInfo? @relation("MacOSSupport", fields: [macosSupportId], references: [id])
  macosSupportId String?
  
  windowsSupport   PlatformInfo? @relation("WindowsSupport", fields: [windowsSupportId], references: [id])
  windowsSupportId String?
  
  // Desktop Environment support
  desktopEnvironments String[]
  
  // GitHub source transparency
  githubUrl     String?
  githubPath    String?
  lastSynced    DateTime @default(now())
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([category])
  @@index([official])
  @@index([default])
  @@index([name])
  @@map("applications")
}

model Plugin {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  type        String   // package-manager, installer, utility, etc.
  priority    Int      @default(50)
  status      String   @default("active") // active, deprecated, experimental
  
  // Capabilities
  supports Json @default("{}")
  
  // Platform support - plugins are typically cross-platform
  platforms String[] @default(["linux", "macos", "windows"])
  
  // GitHub source transparency
  githubUrl     String?
  githubPath    String?
  lastSynced    DateTime @default(now())
  
  // Registry metadata
  downloadCount Int      @default(0)
  lastDownload  DateTime?
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([type])
  @@index([priority])
  @@index([status])
  @@index([name])
  @@map("plugins")
}

model Config {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  category    String   // system, development, desktop, etc.
  type        String   // yaml, json, toml, etc.
  
  // Target platforms
  platforms String[]
  
  // Configuration content
  content   Json
  schema    Json? // JSON schema for validation
  
  // GitHub source transparency
  githubUrl     String?
  githubPath    String?
  lastSynced    DateTime @default(now())
  
  // Usage tracking
  downloadCount Int      @default(0)
  lastDownload  DateTime?
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([category])
  @@index([type])
  @@index([name])
  @@map("configs")
}

model Stack {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  category    String   // web, mobile, data, devops, etc.
  
  // Stack composition
  applications String[] // References to application names
  configs      String[] // References to config names
  plugins      String[] // References to plugin names
  
  // Platform support
  platforms            String[]
  desktopEnvironments  String[]
  
  // Prerequisites
  prerequisites Json @default("[]") // System requirements, other stacks, etc.
  
  // GitHub source transparency
  githubUrl     String?
  githubPath    String?
  lastSynced    DateTime @default(now())
  
  // Usage tracking
  downloadCount Int      @default(0)
  lastDownload  DateTime?
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([category])
  @@index([name])
  @@map("stacks")
}

model PlatformInfo {
  id              String @id @default(cuid())
  installMethod   String
  installCommand  String
  officialSupport Boolean @default(false)
  
  // Alternative installation methods
  alternatives Json @default("[]")
  
  // Relationships
  linuxApplications   Application[] @relation("LinuxSupport")
  macosApplications   Application[] @relation("MacOSSupport") 
  windowsApplications Application[] @relation("WindowsSupport")
  
  @@map("platform_info")
}

model RegistryStats {
  id        String   @id @default(cuid())
  date      DateTime @unique @default(now())
  
  // Counts
  totalApplications Int @default(0)
  totalPlugins      Int @default(0)
  totalConfigs      Int @default(0)
  totalStacks       Int @default(0)
  
  // Platform distribution
  linuxSupported   Int @default(0)
  macosSupported   Int @default(0)
  windowsSupported Int @default(0)
  
  // Activity metrics
  totalDownloads Int @default(0)
  dailyDownloads Int @default(0)
  
  @@map("registry_stats")
}

model SyncLog {
  id        String   @id @default(cuid())
  type      String   // application, plugin, config, stack
  name      String
  action    String   // create, update, delete
  githubUrl String?
  
  // Sync details
  success   Boolean
  error     String?
  changes   Json?    // What changed during sync
  
  createdAt DateTime @default(now())
  
  @@index([type])
  @@index([createdAt])
  @@index([success])
  @@map("sync_logs")
}