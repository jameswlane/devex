FROM ubuntu:latest

# Install required tools
RUN apt-get update && apt-get install -y git bash curl build-essential wget sudo

# Install Go
RUN wget -q https://go.dev/dl/go1.23.1.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go1.23.1.linux-amd64.tar.gz && \
    rm go1.23.1.linux-amd64.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"

# Set up DevEx directory structure
RUN mkdir -p /root/.local/share/devex/bin

# Copy DevEx source code
WORKDIR /root/.local/share/devex

# Copy module files first to leverage Docker's caching mechanism
COPY go.mod go.sum ./

# Fetch dependencies
RUN go mod download

# Copy the rest of the source code
COPY . .

# Build the CLI
RUN go build -v -o /root/.local/share/devex/bin/devex ./cmd/devex

# Add DevEx binary to PATH
ENV PATH="/root/.local/share/devex/bin:${PATH}"

# Default command to test installation
CMD ["bash", "-c", "devex install"]
