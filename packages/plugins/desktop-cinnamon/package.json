{
	"name": "@devex/plugin-desktop-cinnamon",
	"version": "1.0.0",
	"description": "Cinnamon desktop environment configuration plugin for DevEx CLI",
	"main": "main.go",
	"scripts": {
		"build": "task build",
		"test": "task test",
		"lint": "task lint"
	},
	"keywords": [
		"devex",
		"plugin",
		"cinnamon",
		"desktop",
		"linux",
		"mint"
	],
	"author": "DevEx Team",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jameswlane/devex",
		"directory": "packages/plugins/desktop-cinnamon"
	},
	"devex": {
		"plugin": {
			"type": "desktop-environment",
			"platforms": [
				"linux"
			],
			"desktop": "cinnamon",
			"dependencies": [
				"gsettings",
				"dconf",
				"cinnamon-settings"
			],
			"priority": 10,
			"capabilities": {
				"themes": true,
				"wallpapers": true,
				"applets": true,
				"settings": true,
				"backup": true
			}
		}
	}
}
