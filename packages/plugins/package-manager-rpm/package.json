{
	"name": "@devex/plugin-package-manager-rpm",
	"version": "1.0.0",
	"description": "RPM plugin for DevEx CLI",
	"main": "main.go",
	"scripts": {
		"build": "task build",
		"test": "task test",
		"lint": "task lint"
	},
	"keywords": [
		"rpm",
		"redhat",
		"linux"
	],
	"author": "DevEx Team",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jameswlane/devex",
		"directory": "packages/plugins/package-manager-rpm"
	},
	"devex": {
		"plugin": {
			"type": "package-manager",
			"platforms": [
				"linux"
			],
			"dependencies": [
				"rpm"
			],
			"priority": 10,
			"supports": {
				"install": true,
				"remove": true,
				"update": true,
				"search": true,
				"list": true
			}
		}
	}
}
