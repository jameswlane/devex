{
	"name": "@devex/plugin-desktop-cosmic",
	"version": "1.0.0",
	"description": "COSMIC desktop environment configuration plugin for DevEx CLI",
	"main": "main.go",
	"scripts": {
		"build": "task build",
		"test": "task test",
		"lint": "task lint"
	},
	"keywords": [
		"devex",
		"plugin",
		"cosmic",
		"desktop",
		"linux",
		"system76",
		"rust"
	],
	"author": "DevEx Team",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jameswlane/devex",
		"directory": "packages/plugins/desktop-cosmic"
	},
	"devex": {
		"plugin": {
			"type": "desktop-environment",
			"platforms": [
				"linux"
			],
			"desktop": "cosmic",
			"dependencies": [
				"cosmic-settings",
				"cosmic-panel",
				"cosmic-comp"
			],
			"priority": 10,
			"capabilities": {
				"themes": true,
				"wallpapers": true,
				"panels": true,
				"workspaces": true,
				"settings": true,
				"backup": true
			}
		}
	}
}
