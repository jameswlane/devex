{
	"name": "@devex/plugin-desktop-mate",
	"version": "1.0.0",
	"description": "MATE desktop environment configuration plugin for DevEx CLI",
	"main": "main.go",
	"scripts": {
		"build": "task build",
		"test": "task test",
		"lint": "task lint"
	},
	"keywords": [
		"devex",
		"plugin",
		"mate",
		"desktop",
		"linux",
		"gtk"
	],
	"author": "DevEx Team",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jameswlane/devex",
		"directory": "packages/plugins/desktop-mate"
	},
	"devex": {
		"plugin": {
			"type": "desktop-environment",
			"platforms": [
				"linux"
			],
			"desktop": "mate",
			"dependencies": [
				"gsettings",
				"dconf",
				"mate-panel"
			],
			"priority": 10,
			"capabilities": {
				"themes": true,
				"wallpapers": true,
				"panels": true,
				"applets": true,
				"settings": true,
				"backup": true
			}
		}
	}
}
