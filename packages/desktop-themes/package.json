{
	"name": "@devex/desktop-themes",
	"private": true,
	"version": "1.0.0",
	"description": "Desktop theme management plugin for DevEx CLI",
	"main": "main.go",
	"scripts": {
		"build": "go build -o devex-plugin-desktop-themes main.go",
		"dev": "go build -race -o devex-plugin-desktop-themes main.go",
		"test": "go test ./...",
		"lint": "golangci-lint run",
		"mod": "go mod tidy"
	},
	"keywords": [
		"desktop",
		"themes",
		"customization"
	],
	"author": "DevEx Team",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jameswlane/devex",
		"directory": "packages/desktop-themes"
	},
	"devex": {
		"plugin": {
			"type": "desktop",
			"platforms": [
				"linux",
				"darwin"
			],
			"dependencies": [],
			"priority": 4,
			"supports": {
				"apply": true,
				"list": true,
				"backup": true,
				"restore": true
			}
		}
	}
}
