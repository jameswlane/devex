{
  "name": "@devex/system-setup",
  "version": "1.4.0",
  "description": "System setup and configuration plugin for DevEx CLI",
  "private": true,
  "main": "main.go",
  "scripts": {
    "build": "go build -o devex-plugin-system-setup .",
    "test": "go test ./...",
    "dev": "go build -race -o devex-plugin-system-setup main.go",
    "lint": "golangci-lint run",
    "mod": "go mod tidy"
  },
  "dependencies": {
    "@devex/plugin-sdk": "workspace:*"
  },
  "keywords": [
    "system",
    "setup",
    "configuration"
  ],
  "author": "DevEx Team",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jameswlane/devex",
    "directory": "packages/system-setup"
  },
  "devex": {
    "plugin": {
      "type": "system",
      "platforms": [
        "linux",
        "darwin",
        "windows"
      ],
      "dependencies": [],
      "priority": 10,
      "supports": {
        "configure": true,
        "apply": true,
        "validate": true,
        "backup": true
      }
    }
  }
}
