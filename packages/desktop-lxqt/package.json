{
	"name": "@devex/desktop-lxqt",
	"private": true,
	"version": "1.4.1",
	"description": "LXQt desktop environment configuration plugin for DevEx CLI",
	"main": "main.go",
	"scripts": {
		"build": "go build -o devex-plugin-desktop-lxqt .",
		"dev": "go build -race -o devex-plugin-desktop-lxqt main.go",
		"test": "go test ./...",
		"lint": "golangci-lint run",
		"download": "go mod download",
		"mod": "go mod tidy"
	},
	"keywords": [
		"devex",
		"plugin",
		"lxqt",
		"desktop",
		"linux",
		"qt"
	],
	"author": "DevEx Team",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jameswlane/devex",
		"directory": "packages/desktop-lxqt"
	},
	"devex": {
		"plugin": {
			"type": "desktop-environment",
			"platforms": [
				"linux"
			],
			"desktop": "lxqt",
			"dependencies": [
				"lxqt-config",
				"pcmanfm-qt",
				"openbox"
			],
			"priority": 10,
			"capabilities": {
				"themes": true,
				"wallpapers": true,
				"panels": true,
				"settings": true,
				"backup": true
			}
		}
	}
}
